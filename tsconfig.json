{
    "compilerOptions": {
        "target": "es2025",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "noImplicitAny": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": ["jest", "node"]
    },
    "include": ["./src/**/*.ts"],
    "exclude": ["node_modules"]
}