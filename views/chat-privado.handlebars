{{#if error}}
    <div class="alert alert-danger">{{error}}</div>
    <a href="/match" class="btn btn-secondary">Volver a match</a>
{{else}}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="mb-3">
                        {{#if otroUsuario.foto_perfil}}
                            <img src="{{otroUsuario.foto_perfil}}" class="rounded-circle me-2" width="32" height="32" style="object-fit: cover;">
                        {{else}}
                            <i class="bi bi-person-circle me-2"></i>
                        {{/if}}
                        {{otroUsuario.nombre}}
                    </h4>

                    <div id="mensajes-privado" class="border rounded p-3 mb-3" style="height: 300px; overflow-y: auto;"></div>

                    <form id="form-mensaje-privado" class="d-flex gap-2">
                        <input type="text" id="input-mensaje-privado" class="form-control" placeholder="Escribe un mensaje...">
                        <button type="submit" class="btn btn-primary">Enviar</button>
                    </form>

                    <a href="/match" class="btn btn-outline-secondary mt-3">← Volver a match</a>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/chatPrivado.js" data-token="{{token}}" data-otro-usuario-id="{{otroUsuarioId}}" data-mi-usuario-id="{{miUsuarioId}}"></script>
{{/if}}