<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Play N Seek</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <header class="bg-dark text-white p-3">
        <div class="container d-flex justify-content-between align-items-center">
            <h1 class="m-0 h4"><a href="/" class="text-white text-decoration-none">Play N Seek</a></h1>
            <nav>
                <a href="/juegos" class="text-white me-3">Juegos</a>
                <a href="/grupos" class="text-white me-3">Grupos</a>
                {{#if estaLogueado}}
                    <span class="text-white me-3">Hola, {{usuario.nombre}}</span>
                    <a href="/logout" class="btn btn-outline-light btn-sm">Cerrar sesión</a>
                {{else}}
                    <a href="/login" class="btn btn-outline-light btn-sm">Iniciar sesión</a>
                {{/if}}
            </nav>
        </div>
    </header>

    <main class="container mt-4">
        {{{body}}}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>