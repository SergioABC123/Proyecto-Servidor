<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                {{#if exito}}
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 60px;"></i>
                    <h3 class="mt-3">¡Cuenta confirmada!</h3>
                    <p class="text-muted">Ya puedes iniciar sesión con tu cuenta.</p>
                    <a href="/login" class="btn btn-primary">Ir a iniciar sesión</a>
                {{else}}
                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 60px;"></i>
                    <h3 class="mt-3">No se pudo confirmar</h3>
                    <p class="text-muted">{{error}}</p>
                    <a href="/login" class="btn btn-outline-secondary">Volver al login</a>
                {{/if}}
            </div>
        </div>
    </div>
</div> 