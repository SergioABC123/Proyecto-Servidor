{
  "name": "proyecto-servidor",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest",
    "scripts": "tsc",
    "styles": "sass src/styles:public/styles",
    "build": "npm run scripts && npm run styles && copyfiles -u 1 \"public/**/*\" dist",
    "build:clean": "rimraf dist && tsc",
    "start": "node .",
    "dev": "nodemon src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "postinstall": "npm run build:clean",
    "precommit": "eslint && jest && build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SergioABC123/Proyecto-Servidor.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SergioABC123/Proyecto-Servidor/issues"
  },
  "homepage": "https://github.com/SergioABC123/Proyecto-Servidor#readme",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dgraph-js": "^24.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/google-protobuf": "^3.15.12",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "copyfiles": "^2.4.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "directories": {
    "doc": "docs"
  }
}
